# GaoshouPlatform local runtime config template.
#
# Copy this file to `.env.local` on each development machine and edit the
# machine-specific paths. `.env.local` and `.env.<hostname>.local` are ignored
# by git.

# Optional shared data root. Defaults to the repository sibling directory
# `Data` (for this Windows layout: `E:/Projects/Data`).
GAOSHOU_DATA_DIR=E:/Projects/Data

# parquet | clickhouse
MARKET_DATA_BACKEND=parquet

# Local Parquet dataset root. Use an absolute path on each machine.
PARQUET_DATA_DIR=E:/Projects/Data/parquet

# SQLite metadata database. Absolute macOS/Linux paths need four slashes after
# sqlite+aiosqlite:, for example:
# DATABASE_URL=sqlite+aiosqlite:////Users/albert/MyProjects/Data/gaoshou.db
# Windows example:
# DATABASE_URL=sqlite+aiosqlite:///E:/Projects/Data/gaoshou.db
DATABASE_URL=sqlite+aiosqlite:///E:/Projects/Data/gaoshou.db

# DuckDB can use :memory: for local interactive research.
DUCKDB_PATH=:memory:

# Set true only when running the ClickHouse backend.
CLICKHOUSE_ENABLED=false

# Optional services.
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0

# Isolated data sync service. Dev uses 18810; prod uses 8810 in the prod repo.
SYNC_SERVICE_URL=http://127.0.0.1:18810
SYNC_SERVICE_PORT=18810
ENABLE_SYNC_SCHEDULER=true

# Dev ports for this checkout.
BACKEND_PORT=18800
FRONTEND_PORT=13500

# Optional sentiment module integration.
NGA_DATA_DIR=E:/Projects/Data/sentiment/NGAdata
XUEQIU_COOKIE=
NGA_COOKIE=
XUEQIU_CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
XUEQIU_DEBUG_PORT=9222
XUEQIU_USER_DATA_DIR=E:/Projects/Data/sentiment/xueqiu-profile
NGA_BOARD_FID=706

# Local development default.
DEBUG=false
