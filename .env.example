# GaoshouPlatform local runtime config template.
#
# Copy this file to `.env.local` on each development machine and edit the
# machine-specific paths. `.env.local` and `.env.<hostname>.local` are ignored
# by git.

# Optional shared data root. Defaults to the repository sibling directory
# `Data` (for this Windows layout: `E:/Projects/data/BaiduSyncdisk`).
GAOSHOU_DATA_DIR=E:/Projects/data/BaiduSyncdisk

# Current supported backend: parquet.
MARKET_DATA_BACKEND=parquet

# Local Parquet dataset root. Use an absolute path on each machine.
PARQUET_DATA_DIR=E:/Projects/data/BaiduSyncdisk/parquet

# SQLite metadata database. Absolute macOS/Linux paths need four slashes after
# sqlite+aiosqlite:, for example:
# DATABASE_URL=sqlite+aiosqlite:////Users/albert/MyProjects/Data/gaoshou.db
# Windows example:
# DATABASE_URL=sqlite+aiosqlite:///E:/Projects/data/BaiduSyncdisk/gaoshou.db
DATABASE_URL=sqlite+aiosqlite:///E:/Projects/data/BaiduSyncdisk/gaoshou.db

# DuckDB can use :memory: for local interactive research.
DEV_LOCAL_DATA_DIR=E:/Projects/data/BaiduSyncdisk/dev_sample
DEV_PROD_DATA_DIR=E:/Projects/data/BaiduSyncdisk
DUCKDB_PATH=:memory:

# Optional services.
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_DB=0

# Live trading guardrails. Keep both false unless production trading is
# intentionally armed from System Ops.
LIVE_TRADING_ENABLE_ORDER_SUBMIT=false
LIVE_TRADING_AUTO_EXECUTE_ENABLED=false

# Isolated data sync service. Dev uses 18810; prod uses 8810 in the prod repo.
SYNC_SERVICE_URL=http://127.0.0.1:18810
SYNC_SERVICE_PORT=18810
ENABLE_SYNC_SCHEDULER=true

# Dev ports for this checkout.
BACKEND_PORT=18800
FRONTEND_PORT=13500

# Optional sentiment module integration.
NGA_DATA_DIR=E:/Projects/data/BaiduSyncdisk/sentiment/NGAdata
XUEQIU_COOKIE=
NGA_COOKIE=
XUEQIU_CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
XUEQIU_DEBUG_PORT=9222
XUEQIU_USER_DATA_DIR=E:/Projects/data/BaiduSyncdisk/sentiment/xueqiu-profile
NGA_BOARD_FID=706
WECHAT_SOGOU_QUERIES=开盘啦 创始人 股票,开盘啦 A股 股票,龙虎榜 A股 游资,短线 A股 股票,涨停板 A股
WECHAT_SOGOU_ACCOUNTS=陈小群周策略,余哥牛弹琴,佛总晚评,饭统戴老板,表舅是养基大户,奶员外,海里的小龙龙,小群知识营,投资明见,徐小明,天津股侠,王金生,小红帽爱股票,空空道人
WECHAT_SOGOU_COOKIE=
TAOGUBA_BLOG_IDS=2577911:zarili,444409:湖南人,8186648:星辰趋势主升,13186975:主升龙头空空龙,7826561:玫瑰抓龙头,11255090:搞钱老兵,11520081:风一样的胖刺猬,6671396:亿百万实盘
TAOGUBA_COOKIE=
TIEBA_STOCK_BARS=股票,股市,A股,炒股,涨停板
TIEBA_COOKIE=

# Local development default.
DEBUG=false
